---
import data from "../data/nav.json";
---

<nav>
    <a href="/" class="nav-logo">
        <img src="/images/Logo.jpg" alt="Logo" />
        <div class="nav-brand">
            Rescue Dogs
            <span>Schleswig-Flensburg e.V.</span>
        </div>
    </a>

    <button class="burger" id="burger" aria-label="Menü öffnen">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="3" y1="6" x2="21" y2="6" stroke="#FAFAFA" stroke-width="2"></line>
            <line x1="3" y1="12" x2="21" y2="12" stroke="#FAFAFA" stroke-width="2"></line>
            <line x1="3" y1="18" x2="21" y2="18" stroke="#FAFAFA" stroke-width="2"></line>
        </svg>
    </button>
    <ul class="nav-links" id="nav-links">
        {
            data.map((link) => (
                <li>
                    <a href={link.href}>{link.title}</a>
                </li>
            ))
        }
    </ul>
</nav>

<script>
    const burger = document.getElementById("burger");
    const navLinks = document.getElementById("nav-links");

    burger?.addEventListener("click", () => {
        burger.classList.toggle("open");
        navLinks?.classList.toggle("open");
        navLinks?.setAttribute("aria-expanded", "true");
    });
</script>
<style>
    nav {
        background: var(--black);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 3rem;
        border-bottom: 3px solid var(--red);
        position: relative;
    }

    .nav-logo {
        display: flex;
        gap: 1rem;
        align-items: center;
        text-decoration: none;
        img {
            width: 5rem;
            height: auto;
            aspect-ratio: 1;
            object-fit: cover;
        }

        .nav-brand {
            font-family: "Saira", sans-serif;
            font-size: 2rem;
            color: var(--white);
            line-height: 1;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            span {
                font-size: 1rem;
                letter-spacing: 0.2ch;
                color: var(--red);
                font-weight: 300;
                text-transform: uppercase;
            }
        }
    }

    .nav-links {
        display: flex;
        gap: 3rem;
        list-style: none;
        a {
            color: var(--white);
            text-decoration: none;
            font-size: 1rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 500;
            transition: color 0.2s;

            &:hover {
                color: var(--red);
            }
        }
    }

    .burger {
        display: none;
    }

    @media (width < 1024px) {
        nav {
            padding: 0.5rem 1rem;
            height: auto;
            min-height: max-content;
        }

        .burger {
            display: block;
            margin-inline-start: auto;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.25rem;

            svg line {
                transition: all 0.3s;
                transform-origin: center;
            }

            &.open {
                svg line:nth-child(1) {
                    transform: translateY(6px) rotate(45deg);
                }
                svg line:nth-child(2) {
                    opacity: 0;
                }
                svg line:nth-child(3) {
                    transform: translateY(-3px) rotate(-45deg);
                }
            }
        }

        .nav-links {
            flex-direction: column;
            gap: 0;
            height: 0;
            width: 0;
            position: absolute;
            top: 100%;
            left: 0;
            background: var(--black);
            margin-top: 3px;
            visibility: hidden;

            &.open {
                visibility: visible;
                width: 100%;
                height: auto;
            }

            li a {
                display: block;
                padding: 1rem;
                border-bottom: 1px solid var(--dark-gray);
            }
        }
    }
</style>
