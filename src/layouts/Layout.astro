---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { SEO } from "astro-seo";
import "glightbox/dist/css/glightbox.min.css";
---

<!doctype html>
<html lang="de">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>Rescue Dogs Schleswig-Flensburg e.V.</title>
        <SEO
            title="Rescue Dogs Schleswig-Flensburg e.V."
            description="Rettungshundeverein aus Schleswig-Flensburg – wir trainieren Hunde und Hundeführer für die Suche und Rettung vermisster Menschen."
            openGraph={{
                basic: {
                    title: "Rescue Dogs Schleswig-Flensburg e.V.",
                    type: "website",
                    image: "/images/Logo.jpg",
                },
                optional: {
                    locale: "de_DE",
                    siteName: "Rescue Dogs Schleswig-Flensburg e.V.",
                },
            }}
        />
    </head>
    <body>
        <header>
            <Nav />
        </header>
        <slot />
        <Footer />
        <script>
            import GLightbox from "glightbox";
            const lightbox = GLightbox({});
        </script>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100vw;
        height: 100dwh;
    }
</style>
