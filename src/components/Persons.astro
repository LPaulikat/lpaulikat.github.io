---
import data from "../persons.json";
---

<section id="persons" class="section-dark">
    <div class="container">
        <p class="section-label">Wer steckt dahinter</p>
        <h2 class="section-title">Die Menschen</h2>
        <div class="red-bar"></div>
        <p class="section-sub">Das sind die Menschen hinter dem Verein</p>
        <div class="person-grid">
            {
                data.map((team) => (
                    <div class="card">
                        <span class="card__badge">{team.badge}</span>
                        <img class="card__img" src={team.images[0].img.src} alt={team.images[0].img.alt} />
                        <div class="card__body">
                            <h2 class="card__name">{team.name}</h2>
                            <p class="card__desc">{team.description}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .person-grid {
        display: grid;
        gap: 2rem;
        grid-template-rows: auto 500px auto auto;
        @media (width > 1024px) {
            grid-template-columns: repeat(3, 1fr);
        }

        .card {
            display: grid;
            gap: 0;
            position: relative;
            grid-row: span 4;
            grid-template-rows: subgrid;
            .card__img {
                border-top-right-radius: 15px;
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: top center;
            }

            .card__badge {
                display: inline-block;
                width: fit-content;
                background: var(--red-dark);
                color: var(--white);
                font-size: 1rem;
                letter-spacing: 0.5ch;
                text-transform: uppercase;
                padding: 0.25rem 0.75rem;
                font-weight: 500;
                border-top-left-radius: 15px;
                /*border-top-right-radius: 15px;*/
            }

            .card__body {
                display: flex;
                flex-direction: column;
                color: var(--white);
                background: var(--dark-gray);
                padding: 1rem;
                gap: 0.5rem;
                .card__name {
                    font-family: "Saira", sans-serif;
                    font-size: 1.75rem;
                }

                .card__desc {
                    font-size: 1rem;
                }
            }
        }
    }
</style>
