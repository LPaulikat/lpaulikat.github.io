---
interface Props {
    label: string;
    heading: string;
    data: {
        id: string;
        img: {
            src: string;
            alt: string;
        };
        title: string;
        texts: string[];
        list: {
            listLabel: string;
            listItems: {
              bold:string;
              text:string;
              }[];
        }[];
    }[];
}
const { data, label, heading } = Astro.props;
---

<section id="about">
    <div class="container">
        <p class="section-label">{label}</p>
        <h2 class="section-title">{heading}</h2>
        {heading && <div class="red-bar" />}
        <div class="about-grid">
            {
                data &&
                    data.map((about) => (
                        <div class="about-content">
                            {about.img.src && <img class="about-img" src={about.img.src} alt={about.img.alt} />}
                            <div class="about-text">
                                <h3>{about.title}</h3>

                                {about.texts.map((text) => (
                                    <p>{text}</p>
                                ))}
                                {about.list.map((l) =>
                                {l.listLabel && <strong>{l.listLabel}</strong>}
                                <ul>
                                    {l.listItems.map((item) => (
                                        <li>{item.bold && <strong>{item.bold}</strong>}{item.text}</li>
                                    ))}
                                </ul>
                                )}
                            </div>
                        </div>
                    ))
            }
        </div>
    </div>
</section>

<style>
    .about-grid {
        display: grid;
        gap: 2rem;

        @media (width > 1024px) {
            gap: 5rem;
        }
        .about-content {
            display: flex;
            gap: 2.5rem;
            flex-direction: column;

            @media (width > 1024px) {
                flex-direction: row;

                &:nth-child(even) {
                    flex-direction: row-reverse;
                }
            }

            .about-img {
                width: 100%;
                height: auto;
                object-fit: cover;
                aspect-ratio: 4 / 3;
                border-radius: 15px;
            }
            .about-text {
                display: flex;
                flex-direction: column;
                gap: 1.5em;
                @media (width > 1024px) {
                    max-width: 50%;
                }
            }
        }
    }
</style>
