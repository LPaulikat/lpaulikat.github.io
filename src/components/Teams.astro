---
interface Props {
    label: string;
    heading: string;
    text: string;
    data: {
        id: string;
        images: {
            img: {
                src: string;
                alt: string;
            };
        }[];
        badge: string;
        name: string;
        breed: string;
        description: string;
    }[];
}
const { data, label, heading, text } = Astro.props;
---

<section id="teams">
    <div class="container">
        <p class="section-label">{label}</p>
        <h2 class="section-title">{heading}</h2>
        {heading && <div class="red-bar" />}
        <p class="section-sub">
            {text}
        </p>
        <ul class="team-grid">
            {
                data &&
                    data.map((team) => (
                        <li>
                            <article class="card">
                                <img class="card-img" src={team.images[0]?.img.src} alt={team.images[0]?.img.alt} />
                                <div class="card-body">
                                    <span class="badge">{team.badge}</span>

                                    <h3 class="name">
                                        <a href={`/teams/${team.id}`}>{team.name}</a>
                                    </h3>
                                    <div class="info">
                                        <div class="info-inner ">
                                            <p class="breed">{team.breed}</p>
                                            <p class="desc">{team.description}</p>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        </li>
                    ))
            }
        </ul>
    </div>
</section>

<style>
    .team-grid {
        display: grid;
        gap: 2rem;
        list-style: none;
        @media (width > 1024px) {
            grid-template-columns: repeat(3, 1fr);
        }

        .card {
            display: grid;
            overflow: clip;

            .card-img {
                width: 100%;
                height: auto;
                aspect-ratio: 3/6;
                object-fit: cover;
                object-position: top center;

                grid-column: 1/-1;
                grid-row: 1/-1;
                border-radius: 15px;
                @media (width > 1024px) {
                    aspect-ratio: 4/5;
                }
            }
            h3 {
                a {
                    color: var(--white);
                    text-decoration: none;
                    &::before {
                        content: "";
                        position: absolute;
                        inset: 0;
                        z-index: 1;
                        top: -100vh;
                    }
                }
            }

            .card-body {
                --border-width: 2px;
                grid-column: 1/-1;
                grid-row: 1/-1;
                align-self: end;
                position: relative;
                color: var(--white);
                padding: 1rem;
                background-color: var(--black);
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                z-index: 1;
                border-top-right-radius: 15px;
                border-top: var(--border-width) solid var(--red);
                border-right: var(--border-width) solid var(--red);
            }

            .badge {
                position: absolute;
                top: -36px;
                left: 0;
                width: fit-content;
                background-color: var(--black);
                border-top-right-radius: 15px;
                color: var(--white);
                font-size: 1rem;
                letter-spacing: 0.25ch;
                text-transform: uppercase;
                padding: 0.5rem 1rem;
                font-weight: 500;
                border-top: var(--border-width) solid var(--red);
                border-right: var(--border-width) solid var(--red);

                &::after {
                    content: "";
                    position: absolute;
                    bottom: var(--border-width);
                    left: 100%;
                    width: 1rem;
                    height: 1rem;
                    border-top-right-radius: 50%;
                    box-shadow: 4px -4px 0 4px var(--black);
                    border-top: var(--border-width) solid var(--red);
                    border-right: var(--border-width) solid var(--red);
                    rotate: 180deg;
                }
            }
            .name {
                font-family: "Saira", sans-serif;
                font-size: 1.75rem;
            }
            .info {
                display: grid;

                @media (width > 1024px) {
                    grid-template-rows: 0fr;
                    transition: grid-template-rows 0.5s ease;
                }
            }

            .info-inner {
                overflow: hidden;
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }

            &:hover {
                .info {
                    grid-template-rows: 1fr;
                }
            }
        }
    }
</style>
